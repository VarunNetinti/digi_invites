# ─────────────────────────────────────────────────────────────────────────────
# MongoDB Atlas
# Leave empty to use local JSON file storage (data/invitations.json)
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary
# Leave ALL three empty to use local disk storage (public/uploads)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Base URL — required for the archive screenshot feature
# On Vercel this is your deployment URL, e.g. https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
